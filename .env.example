# Google AI API key – used by the Koog AI agent (Gemini)
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Kapso API credentials
# Get these from https://app.kapso.ai → Settings → API Keys
KAPSO_API_KEY=kap_...

# Your Kapso phone number ID
# Found in Kapso dashboard → Phone Numbers
KAPSO_PHONE_NUMBER_ID=647015955153740

# Webhook secret for HMAC-SHA256 signature verification (optional but recommended)
# Set the same value in Kapso dashboard → Webhooks → Secret
KAPSO_WEBHOOK_SECRET=your_webhook_secret_here

# Server port (optional, defaults to 8080)
PORT=8080
